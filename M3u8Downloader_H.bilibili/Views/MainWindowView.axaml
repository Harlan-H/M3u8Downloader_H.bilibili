<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             xmlns:avalonia="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             x:Class="M3u8Downloader_H.bilibili.MainWindowView">
     <Grid RowDefinitions="auto, *,auto">
            <Grid Margin="8" Grid.ColumnDefinitions="*,auto,auto">
                <TextBox Theme="{DynamicResource CompactTextBox}"
                    Grid.Column="0"  
                    ScrollViewer.HorizontalScrollBarVisibility="Hidden"
                    Margin="6"
                    FontSize="16"
                    Text="{Binding RequestUrl,UpdateSourceTrigger=PropertyChanged,Delay=200}" Watermark="视频地址"
                    Classes="clearButton" AcceptsReturn="True">
                </TextBox>

                <Button Grid.Column="1"
                        Command="{Binding StartParseCommand}"
                    Foreground="{DynamicResource MaterialPrimaryMidBrush}"
                    Theme="{DynamicResource MaterialFlatButton}"
                    IsDefault="True"
                    Margin="0,6,6,6"
                    Padding="4">
                    <avalonia:MaterialIcon
                                Width="24"
                                Height="24"
                                Kind="ArrowDown" />
                </Button>
                <!--<Button Grid.Column="2" 
                        Padding="5"
                        Cursor="Hand"
                        IsTabStop="True"
                        Theme="{DynamicResource MaterialFlatButton}" Foreground="{DynamicResource MaterialPrimaryMidBrush}">
                    <avalonia:MaterialIcon
                                Width="24"
                                Height="24"
                                Kind="Settings" />
                </Button>-->
            </Grid>
        <Border Grid.Row="1" BorderThickness="1" Margin="5" BorderBrush="{DynamicResource MaterialPrimaryMidBrush}">
        <ListBox 
            ItemsSource="{Binding PlayLists}"
            SelectedItems="{Binding SelectedVideos}"
            SelectionMode="Multiple,Toggle">
            <ListBox.Styles>
                <Style Selector="ListBoxItem">
                    <Setter Property="Padding" Value="8,4,8,4" />
                </Style>
            </ListBox.Styles>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid ColumnDefinitions="*,auto">
                        <StackPanel  Margin="8,0,0,0"
                                VerticalAlignment="Center"
                                Orientation="Vertical">
                            <TextBlock  TextTrimming="CharacterEllipsis" FontSize="30" >
								<TextBlock.Text>
									<MultiBinding StringFormat="{}{0})  {1}">
                                        <Binding  Path="Page" />
                                        <Binding  Path="Title" />
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                            <TextBlock Margin="0,4,0,0">
								<TextBlock.Text>
									<MultiBinding StringFormat="📅 {0}    ⏱ {1}" >
										<Binding Path="CTime" />
                                        <Binding Path="Duration" />
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                        </StackPanel>
                        
                        <avalonia:MaterialIcon
                                Grid.Column="1"
                                Width="24"
                                Height="24"
                                Margin="8,0,0,0"
                                VerticalAlignment="Center"
                                Kind="Check"
                                IsVisible="{Binding $parent[ListBoxItem].IsSelected}" />
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
            </Border>
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" >
                <Button Command="{Binding ConfirmCommand}"  
                        IsDefault="True"
                        Margin="8" >
                    <Button.Content>
                        <TextBlock>
                            <Run Text="下载"/>
                            <Run Text="(" /><Run Text="{Binding SelectedVideos.Count,FallbackValue=0,Mode=OneWay}" /><Run Text=")"/>
                        </TextBlock>
                    </Button.Content>
                </Button>
                <Button Margin="8" Content="取消" IsCancel="True" Command="{Binding CancelCommand}"/>
        </StackPanel>

    </Grid>
</UserControl>
